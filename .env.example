# Use mock for deterministic local synthesis, or live for OpenAI enhancement.
AI_MODE=mock

# Enable only when AI_MODE=live. This remains server-side.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra

# Real uploads are analyzed by the private service in services/audio-analysis.
MUSIC_ANALYSIS_PROVIDER=http
AUDIO_ANALYSIS_URL=http://127.0.0.1:8788
# Use the same non-empty token in both processes outside local development.
AUDIO_ANALYSIS_TOKEN=
